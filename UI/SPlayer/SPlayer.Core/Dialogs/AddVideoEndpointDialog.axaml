<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dialogModels="clr-namespace:SPlayer.Core.Dialogs.DialogModels"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="200"
        x:Class="SPlayer.Core.Dialogs.AddVideoEndpointDialog"
        x:DataType="dialogModels:AddVideoEndpointViewModel"
        Title="{Binding DialogHeader}"
        Width="460" SizeToContent="Height"
        CanResize="False">

    <Design.DataContext>
        <dialogModels:AddVideoEndpointViewModel/>
    </Design.DataContext>

    <StackPanel Margin="20,16" Spacing="10">

        <!-- §sdl3-output — backend description blurb, mirrors the "+ Video" split-button choice. -->
        <Border Background="{DynamicResource SystemControlBackgroundAltMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,8">
            <TextBlock Text="{Binding BackendDescription}"
                       TextWrapping="Wrap"
                       FontSize="11"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </Border>

        <StackPanel Spacing="4">
            <TextBlock Text="Name" FontSize="12"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <TextBox Text="{Binding Title}"/>
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="Screen" FontSize="12"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <ComboBox ItemsSource="{Binding AvailableScreens}"
                      SelectedItem="{Binding SelectedScreen}"
                      HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                    <DataTemplate DataType="dialogModels:ScreenItem">
                        <TextBlock Text="{Binding Label}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <Grid ColumnDefinitions="*, 8, *" Margin="0,6,0,0">
            <Button Grid.Column="0"
                    Content="Add Output"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    IsDefault="True"
                    Command="{Binding AddCommand}"
                    CommandParameter="{Binding $parent[Window]}"/>
            <Button Grid.Column="2"
                    Content="Cancel"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    IsCancel="True"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding $parent[Window]}"/>
        </Grid>

    </StackPanel>

</Window>
