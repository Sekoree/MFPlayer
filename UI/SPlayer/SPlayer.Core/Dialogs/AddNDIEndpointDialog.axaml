<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dialogModels="clr-namespace:SPlayer.Core.Dialogs.DialogModels"
        mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="400"
        x:Class="SPlayer.Core.Dialogs.AddNDIEndpointDialog"
        x:DataType="dialogModels:AddNDIEndpointViewModel"
        Title="Add NDI Output"
        Width="450" SizeToContent="Height"
        CanResize="False">

    <Design.DataContext>
        <dialogModels:AddNDIEndpointViewModel/>
    </Design.DataContext>

    <StackPanel Margin="20,16" Spacing="10">

        <StackPanel Spacing="4">
            <TextBlock Text="Sender Name" FontSize="12"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <TextBox Text="{Binding SenderName}"/>
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="Preset" FontSize="12"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <ComboBox ItemsSource="{Binding Presets}"
                      SelectedItem="{Binding SelectedPreset}"
                      HorizontalAlignment="Stretch"/>
        </StackPanel>

        <StackPanel Spacing="4" Margin="0,4,0,0">
            <TextBlock Text="This sender carries" FontSize="12"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <TextBlock Text="You can use audio only, video only, or both on one NDI name."
                       FontSize="11" Opacity="0.85" TextWrapping="Wrap" MaxWidth="400"/>
            <ComboBox SelectedIndex="{Binding StreamModeIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
                <ComboBoxItem>Audio and video</ComboBoxItem>
                <ComboBoxItem>Audio only</ComboBoxItem>
                <ComboBoxItem>Video only</ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <StackPanel Spacing="4" Margin="0,4,0,0"
                    IsEnabled="{Binding IsVideoEnabled}">
            <TextBlock Text="Video pixel format" FontSize="12"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <ComboBox ItemsSource="{Binding PixelFormats}"
                      SelectedItem="{Binding SelectedPixelFormat}"
                      HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                    <DataTemplate DataType="dialogModels:NdiPixelFormatChoice">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding Label}" FontWeight="Medium"/>
                            <TextBlock Text="{Binding Hint}" FontSize="11" Opacity="0.75"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="Auto (recommended) sends whatever the source produces — no conversion, no color-space mis-tagging. Pick a fixed format only if you need a specific wire format. UHD sources (&gt;1920×1080) automatically fall back to RGBA inside the endpoint."
                       FontSize="11" Opacity="0.75" TextWrapping="Wrap" MaxWidth="400"/>
        </StackPanel>

        <Grid ColumnDefinitions="*, 8, *" Margin="0,6,0,0">
            <Button Grid.Column="0"
                    Content="Add Output"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    IsDefault="True"
                    Command="{Binding AddCommand}"
                    CommandParameter="{Binding $parent[Window]}"/>
            <Button Grid.Column="2"
                    Content="Cancel"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    IsCancel="True"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding $parent[Window]}"/>
        </Grid>

    </StackPanel>

</Window>
