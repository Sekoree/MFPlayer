<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dialogModels="clr-namespace:SPlayer.Core.Dialogs.DialogModels"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="500"
        x:Class="SPlayer.Core.Dialogs.PlayNDISourceDialog"
        x:DataType="dialogModels:PlayNDISourceViewModel"
        Title="Play NDI Source"
        Width="500" SizeToContent="Height"
        CanResize="False">

    <Design.DataContext>
        <dialogModels:PlayNDISourceViewModel/>
    </Design.DataContext>

    <StackPanel Margin="20,16" Spacing="10">

        <TextBlock Text="Discovered NDI sources" FontSize="12"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="3">
            <ListBox MaxHeight="220"
                     ItemsSource="{Binding DiscoveredSources}"
                     SelectedItem="{Binding SelectedSource, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="dialogModels:NdiSourceRow">
                        <StackPanel Spacing="2" Margin="2">
                            <TextBlock Text="{Binding Name}" FontWeight="Medium"/>
                            <TextBlock Text="{Binding Url, FallbackValue=''}"
                                       FontSize="11"
                                       Opacity="0.75"
                                       IsVisible="{Binding Url, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <TextBlock Text="{Binding StatusMessage}"
                   FontSize="11"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                   TextWrapping="Wrap"/>

        <StackPanel Spacing="4" Margin="0,4,0,0">
            <TextBlock Text="Or enter a source name (overrides selection)" FontSize="12"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <TextBox Text="{Binding ManualName, Mode=TwoWay}"
                     PlaceholderText="HOSTNAME (Source)  or  partial pattern like 'OBS'"/>
            <TextBlock Text="Names like 'HOSTNAME (OBS)' work too — substring matches are honoured."
                       FontSize="11" Opacity="0.75" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Spacing="4" Margin="0,4,0,0">
            <TextBlock Text="Preset" FontSize="12"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <ComboBox ItemsSource="{Binding Presets}"
                      SelectedItem="{Binding SelectedPreset}"
                      HorizontalAlignment="Stretch"/>
        </StackPanel>

        <Grid ColumnDefinitions="*, 8, *" Margin="0,8,0,0">
            <Button Grid.Column="0"
                    Content="Play"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    IsDefault="True"
                    Command="{Binding AddCommand}"
                    CommandParameter="{Binding $parent[Window]}"/>
            <Button Grid.Column="2"
                    Content="Cancel"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    IsCancel="True"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding $parent[Window]}"/>
        </Grid>

    </StackPanel>

</Window>
