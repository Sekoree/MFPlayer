<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SPlayer.Core.ViewModels"
             xmlns:views="clr-namespace:SPlayer.Core.Views"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SPlayer.Core.Views.MainView"
             x:DataType="vm:MainViewModel">
    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
         to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainViewModel />
    </Design.DataContext>
    
    <TabControl TabStripPlacement="Left">
        <TabItem Header="Outputs">
            <views:OutputView DataContext="{Binding Outputs}" />
        </TabItem>
        
        <TabItem Header="Player">
            <views:PlayerView DataContext="{Binding Player}" />
        </TabItem>
    </TabControl>
    
</UserControl>