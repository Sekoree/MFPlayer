<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SPlayer.Core.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
             x:Class="SPlayer.Core.Views.PlayerView"
             x:DataType="vm:PlayerViewModel">

    <UserControl.Styles>
        <Style Selector="Ellipse.status">
            <Setter Property="Fill" Value="#757575"/>
        </Style>
        <Style Selector="Ellipse.status.running">
            <Setter Property="Fill" Value="#4CAF50"/>
        </Style>
        <Style Selector="TextBlock.playing">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4CAF50"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *, Auto, Auto">

        <!-- Toolbar -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="Player"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,10,0"/>
                <Button Content="+ Tab"
                        Command="{Binding AddPlaylistTabCommand}"
                        Margin="0,0,4,0"/>
                <Button Content="− Tab"
                        Command="{Binding RemoveSelectedPlaylistCommand}"
                        Margin="0,0,4,0"/>
                <Button Content="Load M3U…"
                        Command="{Binding LoadM3uCommand}"
                        CommandParameter="{Binding $parent[Window]}"
                        Margin="0,0,4,0"/>
                <Button Content="Batch…"
                        Command="{Binding LoadM3uBatchCommand}"
                        CommandParameter="{Binding $parent[Window]}"
                        Margin="0,0,4,0"/>
                <Button Content="+ Files"
                        Command="{Binding AddMediaFilesCommand}"
                        CommandParameter="{Binding $parent[Window]}"
                        Margin="0,0,4,0"/>
                <Button Content="Save M3U…"
                        Command="{Binding SaveCurrentPlaylistAsCommand}"
                        CommandParameter="{Binding $parent[Window]}"
                        Margin="0,0,4,0"/>
                <Button Content="Save all…"
                        Command="{Binding SaveAllPlaylistsToFolderCommand}"
                        CommandParameter="{Binding $parent[Window]}"/>
            </WrapPanel>
        </Border>

        <!-- Body: output routing + playlists -->
        <Grid Grid.Row="1" RowDefinitions="Auto, *" Margin="12,10,12,0">

            <!-- OUTPUTS routing -->
            <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,10">
                <Grid ColumnDefinitions="Auto, *">
                    <TextBlock Grid.Column="0"
                               Text="OUTPUTS"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Margin="0,0,8,0"/>
                    <Border Grid.Column="1"
                            Height="1"
                            VerticalAlignment="Center"
                            Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                </Grid>
                <TextBlock IsVisible="{Binding OutputRoutingLocked}"
                           Text="Routing is locked while playing or paused — stop to change."
                           TextWrapping="Wrap"
                           FontSize="11"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Clock source:"
                               FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               VerticalAlignment="Center"/>
                    <ComboBox MinWidth="280"
                              ItemsSource="{Binding ClockChoices}"
                              SelectedItem="{Binding SelectedClockChoice, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="vm:ClockChoiceItem">
                                <TextBlock Text="{Binding Label}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <ScrollViewer MaxHeight="180">
                    <ItemsControl ItemsSource="{Binding OutputRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:PlayerOutputRowViewModel">
                                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10,6"
                                        Margin="0,0,0,4">
                                    <StackPanel Spacing="4">
                                        <Grid ColumnDefinitions="Auto, 24, *">
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      IsEnabled="{Binding IsSelectedEnabled}"
                                                      VerticalAlignment="Center"/>
                                            <Ellipse Grid.Column="1"
                                                     Classes="status"
                                                     Classes.running="{Binding IsRowAvailable}"
                                                     Width="8" Height="8"
                                                     VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        Spacing="4"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Subtitle}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                                <TextBlock Text="—"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13"
                                                           FontWeight="Medium"/>
                                                <TextBlock Text="(not started)"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                           IsVisible="{Binding IsOffline}"/>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel IsVisible="{Binding ShowAveStreamPicker}"
                                                    Orientation="Horizontal"
                                                    Spacing="8"
                                                    Margin="36,0,0,0">
                                            <TextBlock Text="NDI send:"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       VerticalAlignment="Center"/>
                                            <ComboBox MinWidth="180"
                                                      IsEnabled="{Binding IsSelectedEnabled}"
                                                      SelectedIndex="{Binding NdiAveToPlayerIndex, Mode=TwoWay}">
                                                <ComboBoxItem>Audio and video</ComboBoxItem>
                                                <ComboBoxItem>Audio only</ComboBoxItem>
                                                <ComboBoxItem>Video only</ComboBoxItem>
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <!-- PLAYLIST -->
            <Grid Grid.Row="1" RowDefinitions="Auto, Auto, *">
                <Grid Grid.Row="0" ColumnDefinitions="Auto, *" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0"
                               Text="PLAYLIST"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Margin="0,0,8,0"/>
                    <Border Grid.Column="1"
                            Height="1"
                            VerticalAlignment="Center"
                            Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                </Grid>

                <!-- Playlist toolbar: rename, clear, output overrides -->
                <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="0,0,0,6">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBox Width="200"
                                 PlaceholderText="Playlist title"
                                 Text="{Binding SelectedPlaylist.Title, Mode=TwoWay, FallbackValue=''}"
                                 IsEnabled="{Binding SelectedPlaylist, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        <Button Content="Clear"
                                Command="{Binding ClearCurrentPlaylistCommand}"
                                IsEnabled="{Binding SelectedPlaylist, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock IsVisible="{Binding SelectedPlaylist.HasOutputOverrides, FallbackValue=False}"
                                   Text="Outputs: override active"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Foreground="#4CAF50"/>
                        <Button Content="Save outputs as override"
                                Command="{Binding UseOutputOverridesForPlaylistCommand}"
                                ToolTip.Tip="Save the current output selection so this playlist always uses these outputs."/>
                        <Button Content="Use defaults"
                                Command="{Binding ClearOutputOverridesForPlaylistCommand}"
                                IsEnabled="{Binding SelectedPlaylist.HasOutputOverrides, FallbackValue=False}"
                                ToolTip.Tip="Clear playlist-specific outputs and fall back to the global default-outputs from Settings."/>
                    </StackPanel>
                </Grid>

                <TabControl Grid.Row="2"
                            ItemsSource="{Binding Playlists}"
                            SelectedItem="{Binding SelectedPlaylist}">
                    <TabControl.ItemTemplate>
                        <DataTemplate DataType="vm:PlaylistDocumentViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding Title}"/>
                                <TextBlock Text="●"
                                           FontSize="10"
                                           Foreground="#4CAF50"
                                           IsVisible="{Binding HasOutputOverrides}"
                                           ToolTip.Tip="Has output overrides"/>
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate DataType="vm:PlaylistDocumentViewModel">
                            <ListBox ItemsSource="{Binding Entries}"
                                     SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                                     DoubleTapped="PlaylistEntry_OnDoubleTapped"
                                     KeyDown="PlaylistList_OnKeyDown">
                                <ListBox.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuItem Header="Move up"
                                                  Command="{Binding MoveEntryUpCommand}"
                                                  CommandParameter="{Binding SelectedEntry}"/>
                                        <MenuItem Header="Move down"
                                                  Command="{Binding MoveEntryDownCommand}"
                                                  CommandParameter="{Binding SelectedEntry}"/>
                                        <Separator/>
                                        <MenuItem Header="Remove"
                                                  Command="{Binding RemoveSelectedCommand}"/>
                                        <MenuItem Header="Clear playlist"
                                                  Command="{Binding ClearEntriesCommand}"/>
                                    </MenuFlyout>
                                </ListBox.ContextFlyout>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="vm:PlaylistEntry">
                                        <Grid ColumnDefinitions="14, *" Margin="0,1">
                                            <TextBlock Grid.Column="0"
                                                       Text="▶"
                                                       FontSize="10"
                                                       Foreground="#4CAF50"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding IsPlaying}"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DisplayName}"
                                                       Padding="2"
                                                       Classes.playing="{Binding IsPlaying}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </Grid>
        </Grid>

        <!-- Transport -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,10">
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="Auto, *">
                    <TextBlock Grid.Column="0"
                               Text="TRANSPORT"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Margin="0,0,8,0"/>
                    <Border Grid.Column="1"
                            Height="1"
                            VerticalAlignment="Center"
                            Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button Content="⏮" Command="{Binding PlayPreviousInPlaylistCommand}" Padding="8,4" MinWidth="34"/>
                    <Button Content="▶" Command="{Binding PlayCommand}" Padding="10,4" MinWidth="34"/>
                    <Button Content="⏸" Command="{Binding PauseCommand}" IsEnabled="{Binding CanPause}" Padding="8,4" MinWidth="34"/>
                    <Button Content="⏹" Command="{Binding StopCommand}" IsEnabled="{Binding CanStop}" Padding="8,4" MinWidth="34"/>
                    <Button Content="⏭" Command="{Binding PlayNextInPlaylistCommand}" Padding="8,4" MinWidth="34"/>
                    <TextBlock Text="{Binding StateLabel}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>
                <Slider x:Name="SeekSlider"
                        Minimum="0" Maximum="1"
                        IsSnapToTickEnabled="False"
                        Value="{Binding SeekNormalized, Mode=TwoWay}"/>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="{Binding PositionText}" MinWidth="48" FontSize="12"/>
                    <TextBlock Text="/"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock Text="{Binding DurationText}" MinWidth="48" FontSize="12"/>
                    <TextBlock Text="Volume"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <Slider Width="160"
                            Minimum="0" Maximum="200"
                            Value="{Binding VolumePercent, Mode=TwoWay}"
                            VerticalAlignment="Center"/>
                    <CheckBox IsChecked="{Binding Loop, Mode=TwoWay}" Content="Loop" FontSize="12"/>
                    <CheckBox IsChecked="{Binding AutoAdvance, Mode=TwoWay}" Content="Auto-advance" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Status -->
        <TextBlock Grid.Row="3"
                   Margin="12,4,12,8"
                   TextWrapping="Wrap"
                   Text="{Binding StatusMessage}"
                   FontSize="11"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

    </Grid>
</UserControl>
