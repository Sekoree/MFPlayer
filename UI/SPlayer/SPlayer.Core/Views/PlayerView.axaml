<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SPlayer.Core.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
             x:Class="SPlayer.Core.Views.PlayerView"
             x:DataType="vm:PlayerViewModel">

    <UserControl.Styles>
        <Style Selector="Ellipse.status">
            <Setter Property="Fill" Value="#757575"/>
        </Style>
        <Style Selector="Ellipse.status.running">
            <Setter Property="Fill" Value="#4CAF50"/>
        </Style>
        <Style Selector="TextBlock.playing">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4CAF50"/>
        </Style>
        <!-- Big transport buttons in the left rail. -->
        <Style Selector="Button.transport">
            <Setter Property="MinWidth" Value="50"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.transport.primary">
            <Setter Property="MinHeight" Value="56"/>
            <Setter Property="FontSize" Value="22"/>
        </Style>
    </UserControl.Styles>

    <!-- Top: Menu bar
         Bottom: Position / time / seek-to bar
         Center: 3-column split — Transport rail | Playlist focus | Outputs side panel -->
    <Grid RowDefinitions="Auto, *, Auto, Auto">

        <!-- ── Top menu bar ──────────────────────────────────────────────── -->
        <Menu Grid.Row="0"
              Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <MenuItem Header="_File">
                <MenuItem Header="Add files…"
                          Command="{Binding AddMediaFilesCommand}"
                          CommandParameter="{Binding $parent[Window]}"/>
                <Separator/>
                <MenuItem Header="Open M3U…"
                          Command="{Binding LoadM3uCommand}"
                          CommandParameter="{Binding $parent[Window]}"/>
                <MenuItem Header="Open M3U batch…"
                          Command="{Binding LoadM3uBatchCommand}"
                          CommandParameter="{Binding $parent[Window]}"/>
                <Separator/>
                <MenuItem Header="Save current playlist as M3U…"
                          Command="{Binding SaveCurrentPlaylistAsCommand}"
                          CommandParameter="{Binding $parent[Window]}"/>
                <MenuItem Header="Save all playlists to folder…"
                          Command="{Binding SaveAllPlaylistsToFolderCommand}"
                          CommandParameter="{Binding $parent[Window]}"/>
            </MenuItem>

            <MenuItem Header="_Playlist">
                <MenuItem Header="New tab"
                          Command="{Binding AddPlaylistTabCommand}"/>
                <MenuItem Header="Remove current tab"
                          Command="{Binding RemoveSelectedPlaylistCommand}"/>
                <Separator/>
                <MenuItem Header="Clear current"
                          Command="{Binding ClearCurrentPlaylistCommand}"/>
                <Separator/>
                <MenuItem Header="Save outputs as override for this tab"
                          Command="{Binding UseOutputOverridesForPlaylistCommand}"/>
                <MenuItem Header="Use default outputs for this tab"
                          Command="{Binding ClearOutputOverridesForPlaylistCommand}"/>
            </MenuItem>

            <MenuItem Header="_NDI">
                <MenuItem Header="Play NDI source…"
                          Command="{Binding OpenNdiSourceDialogCommand}"
                          CommandParameter="{Binding $parent[Window]}"/>
            </MenuItem>
        </Menu>

        <!-- ── Center: 3-column split ────────────────────────────────────── -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto, *, 320">

            <!-- ── Left transport rail ─────────────────────────────────── -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="0,0,1,0"
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    Padding="10,12"
                    Width="170">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="8">
                        <TextBlock Text="TRANSPORT"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

                        <Button Classes="transport primary"
                                Content="▶"
                                Command="{Binding PlayCommand}"
                                ToolTip.Tip="Play selected entry"/>
                        <Grid ColumnDefinitions="*, 4, *">
                            <Button Grid.Column="0"
                                    Classes="transport"
                                    Content="⏸"
                                    IsEnabled="{Binding CanPause}"
                                    Command="{Binding PauseCommand}"
                                    ToolTip.Tip="Pause"/>
                            <Button Grid.Column="2"
                                    Classes="transport"
                                    Content="⏹"
                                    IsEnabled="{Binding CanStop}"
                                    Command="{Binding StopCommand}"
                                    ToolTip.Tip="Stop"/>
                        </Grid>
                        <Grid ColumnDefinitions="*, 4, *">
                            <Button Grid.Column="0"
                                    Classes="transport"
                                    Content="⏮"
                                    Command="{Binding PlayPreviousInPlaylistCommand}"
                                    ToolTip.Tip="Previous in playlist"/>
                            <Button Grid.Column="2"
                                    Classes="transport"
                                    Content="⏭"
                                    Command="{Binding PlayNextInPlaylistCommand}"
                                    ToolTip.Tip="Next in playlist"/>
                        </Grid>

                        <Border Height="1"
                                Margin="0,6"
                                Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>

                        <TextBlock Text="VOLUME"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <Slider Minimum="0" Maximum="200"
                                Value="{Binding VolumePercent, Mode=TwoWay}"/>
                        <TextBlock Text="{Binding VolumePercent, StringFormat='{}{0:0}%'}"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

                        <Border Height="1"
                                Margin="0,6"
                                Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>

                        <CheckBox Content="Loop" FontSize="12"
                                  IsChecked="{Binding Loop, Mode=TwoWay}"/>
                        <CheckBox Content="Auto-advance" FontSize="12"
                                  IsChecked="{Binding AutoAdvance, Mode=TwoWay}"/>

                        <Border Height="1"
                                Margin="0,6"
                                Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>

                        <StackPanel Orientation="Horizontal" Spacing="6"
                                    HorizontalAlignment="Center">
                            <Ellipse Classes="status"
                                     Classes.running="{Binding CanPause}"
                                     Width="9" Height="9"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding StateLabel}"
                                       FontSize="11"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── Center: Playlist focus ──────────────────────────────── -->
            <Grid Grid.Column="1" RowDefinitions="Auto, Auto, *" Margin="12,10,12,4">

                <Grid Grid.Row="0" ColumnDefinitions="Auto, *" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0"
                               Text="PLAYLIST"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Margin="0,0,8,0"/>
                    <Border Grid.Column="1"
                            Height="1"
                            VerticalAlignment="Center"
                            Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                </Grid>

                <!-- Playlist toolbar: title, +Tab, −Tab, Add files, Clear, override flags -->
                <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="0,0,0,6">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Button Content="+ Tab"
                                Command="{Binding AddPlaylistTabCommand}"
                                ToolTip.Tip="Add a new playlist tab."/>
                        <Button Content="− Tab"
                                Command="{Binding RemoveSelectedPlaylistCommand}"
                                ToolTip.Tip="Remove the selected tab."/>
                        <Button Content="+ Files"
                                Command="{Binding AddMediaFilesCommand}"
                                CommandParameter="{Binding $parent[Window]}"
                                ToolTip.Tip="Add audio/video files to this playlist."/>
                        <Border Width="1"
                                Margin="2,2"
                                Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                        <TextBox Width="220"
                                 PlaceholderText="Playlist title"
                                 Text="{Binding SelectedPlaylist.Title, Mode=TwoWay, FallbackValue=''}"
                                 IsEnabled="{Binding SelectedPlaylist, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        <Button Content="Clear"
                                Command="{Binding ClearCurrentPlaylistCommand}"
                                IsEnabled="{Binding SelectedPlaylist, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock IsVisible="{Binding SelectedPlaylist.HasOutputOverrides, FallbackValue=False}"
                                   Text="● Output override active"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Foreground="#4CAF50"/>
                    </StackPanel>
                </Grid>

                <TabControl Grid.Row="2"
                            ItemsSource="{Binding Playlists}"
                            SelectedItem="{Binding SelectedPlaylist}">
                    <TabControl.ItemTemplate>
                        <DataTemplate DataType="vm:PlaylistDocumentViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding Title}"/>
                                <TextBlock Text="●"
                                           FontSize="10"
                                           Foreground="#4CAF50"
                                           IsVisible="{Binding HasOutputOverrides}"
                                           ToolTip.Tip="Has output overrides"/>
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate DataType="vm:PlaylistDocumentViewModel">
                            <ListBox ItemsSource="{Binding Entries}"
                                     SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                                     DoubleTapped="PlaylistEntry_OnDoubleTapped"
                                     KeyDown="PlaylistList_OnKeyDown">
                                <ListBox.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuItem Header="Move up"
                                                  Command="{Binding MoveEntryUpCommand}"
                                                  CommandParameter="{Binding SelectedEntry}"/>
                                        <MenuItem Header="Move down"
                                                  Command="{Binding MoveEntryDownCommand}"
                                                  CommandParameter="{Binding SelectedEntry}"/>
                                        <Separator/>
                                        <MenuItem Header="Remove"
                                                  Command="{Binding RemoveSelectedCommand}"/>
                                        <MenuItem Header="Clear playlist"
                                                  Command="{Binding ClearEntriesCommand}"/>
                                    </MenuFlyout>
                                </ListBox.ContextFlyout>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="vm:PlaylistEntry">
                                        <Grid ColumnDefinitions="14, *" Margin="0,2">
                                            <TextBlock Grid.Column="0"
                                                       Text="▶"
                                                       FontSize="11"
                                                       Foreground="#4CAF50"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding IsPlaying}"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DisplayName}"
                                                       Padding="2"
                                                       Classes.playing="{Binding IsPlaying}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </Grid>

            <!-- ── Right: Output routing (collapsible focus) ────────────── -->
            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1,0,0,0"
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    Padding="10,12">
                <Grid RowDefinitions="Auto, Auto, Auto, Auto, *">
                    <TextBlock Grid.Row="0"
                               Text="OUTPUTS"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="1"
                               IsVisible="{Binding OutputRoutingLocked}"
                               Text="Locked while playing — stop to change."
                               TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Margin="0,0,0,6"/>

                    <StackPanel Grid.Row="2" Spacing="4" Margin="0,0,0,6">
                        <TextBlock Text="Clock source"
                                   FontSize="11"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <ComboBox HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding ClockChoices}"
                                  SelectedItem="{Binding SelectedClockChoice, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="vm:ClockChoiceItem">
                                    <TextBlock Text="{Binding Label}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                        <Button Content="Save outputs as override"
                                FontSize="11"
                                Command="{Binding UseOutputOverridesForPlaylistCommand}"
                                ToolTip.Tip="Save the current output selection so this playlist always uses these outputs."/>
                        <Button Content="Use defaults"
                                FontSize="11"
                                Command="{Binding ClearOutputOverridesForPlaylistCommand}"
                                IsEnabled="{Binding SelectedPlaylist.HasOutputOverrides, FallbackValue=False}"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="4">
                        <ItemsControl ItemsSource="{Binding OutputRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:PlayerOutputRowViewModel">
                                    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8,6"
                                            Margin="0,0,0,4">
                                        <StackPanel Spacing="4">
                                            <Grid ColumnDefinitions="Auto, 18, *">
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          IsEnabled="{Binding IsSelectedEnabled}"
                                                          VerticalAlignment="Center"/>
                                                <Ellipse Grid.Column="1"
                                                         Classes="status"
                                                         Classes.running="{Binding IsRowAvailable}"
                                                         Width="8" Height="8"
                                                         VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="2"
                                                            Orientation="Vertical"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="12"
                                                               FontWeight="Medium"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="{Binding Subtitle}"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                                        <TextBlock Text="(not started)"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                                   IsVisible="{Binding IsOffline}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                            <StackPanel IsVisible="{Binding ShowAveStreamPicker}"
                                                        Orientation="Horizontal"
                                                        Spacing="6"
                                                        Margin="26,0,0,0">
                                                <TextBlock Text="NDI:"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                           VerticalAlignment="Center"/>
                                                <ComboBox MinWidth="140"
                                                          IsEnabled="{Binding IsSelectedEnabled}"
                                                          SelectedIndex="{Binding NdiAveToPlayerIndex, Mode=TwoWay}">
                                                    <ComboBoxItem>Audio + video</ComboBoxItem>
                                                    <ComboBoxItem>Audio only</ComboBoxItem>
                                                    <ComboBoxItem>Video only</ComboBoxItem>
                                                </ComboBox>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Bottom: Position bar with full timing + Seek-to ───────── -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto">
                <Slider Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                        x:Name="SeekSlider"
                        Minimum="0" Maximum="1"
                        IsSnapToTickEnabled="False"
                        Value="{Binding SeekNormalized, Mode=TwoWay}"/>

                <StackPanel Grid.Row="1" Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center"
                            Margin="0,4,0,0">
                    <TextBlock Text="{Binding PositionText}"
                               MinWidth="56" FontSize="13" FontWeight="Medium"/>
                    <TextBlock Text="/" FontSize="13"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock Text="{Binding DurationText}"
                               MinWidth="56" FontSize="13"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock Text="{Binding RemainingText}"
                               MinWidth="64" FontSize="13"
                               Margin="6,0,0,0"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               ToolTip.Tip="Time remaining"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center"
                            Margin="0,4,0,0">
                    <TextBlock Text="Seek to:" FontSize="11"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox x:Name="SeekToInput"
                             Width="110"
                             FontSize="12"
                             PlaceholderText="MM:SS"
                             Text="{Binding SeekToTimestampInput, Mode=TwoWay}"
                             KeyDown="SeekToInput_OnKeyDown"
                             ToolTip.Tip="HH:MM:SS, MM:SS, or seconds. Press Enter to jump."/>
                    <Button Content="Go"
                            Command="{Binding SeekToTimestampCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Status line ───────────────────────────────────────────── -->
        <TextBlock Grid.Row="3"
                   Margin="12,4,12,8"
                   TextWrapping="Wrap"
                   Text="{Binding StatusMessage}"
                   FontSize="11"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

    </Grid>
</UserControl>
