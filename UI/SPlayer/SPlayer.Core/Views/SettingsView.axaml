<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SPlayer.Core.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="SPlayer.Core.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- Toolbar -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Settings"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,10,0"/>
                <Button Content="Restore defaults"
                        Command="{Binding RestoreDefaultsCommand}"/>
                <Button Content="Open settings folder"
                        Command="{Binding OpenSettingsLocationCommand}"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="12,10" Spacing="20" MaxWidth="900" HorizontalAlignment="Stretch">

                <!-- Default outputs -->
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="Auto, *">
                        <TextBlock Grid.Column="0" Text="DEFAULT OUTPUTS"
                                   FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Margin="0,0,8,0"/>
                        <Border Grid.Column="1" Height="1" VerticalAlignment="Center"
                                Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                    </Grid>
                    <TextBlock TextWrapping="Wrap" FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Text="Outputs ticked here will be auto-selected on the Player tab whenever a fresh playlist starts. Per-playlist overrides (Player tab) take precedence."/>
                    <ItemsControl ItemsSource="{Binding AvailableOutputs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:DefaultOutputItemViewModel">
                                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10,6"
                                        Margin="0,0,0,4">
                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsDefault, Mode=TwoWay}"
                                                  VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                                    Margin="8,0,8,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Kind}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                            <TextBlock Text="—" FontSize="11"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"/>
                                        </StackPanel>
                                        <ComboBox Grid.Column="2"
                                                  IsVisible="{Binding IsNdi}"
                                                  SelectedIndex="{Binding NdiAveIndex, Mode=TwoWay}"
                                                  MinWidth="160">
                                            <ComboBoxItem>Audio and video</ComboBoxItem>
                                            <ComboBoxItem>Audio only</ComboBoxItem>
                                            <ComboBoxItem>Video only</ComboBoxItem>
                                        </ComboBox>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock IsVisible="{Binding !AvailableOutputs.Count}"
                               Text="No outputs configured yet. Add them on the Outputs tab."
                               FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>

                <!-- Player defaults -->
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="Auto, *">
                        <TextBlock Grid.Column="0" Text="PLAYER DEFAULTS"
                                   FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Margin="0,0,8,0"/>
                        <Border Grid.Column="1" Height="1" VerticalAlignment="Center"
                                Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto, Auto, Auto" RowSpacing="6" ColumnSpacing="12">
                        <CheckBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                  IsChecked="{Binding AutoAdvance, Mode=TwoWay}"
                                  Content="Auto-advance to next track on end"/>
                        <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                  IsChecked="{Binding Loop, Mode=TwoWay}"
                                  Content="Loop the current track by default"/>
                        <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                  IsChecked="{Binding RememberPlaylistOverrides, Mode=TwoWay}"
                                  Content="Save per-playlist output overrides to settings"/>
                        <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                  IsChecked="{Binding LimitRenderFpsToSource, Mode=TwoWay}"
                                  Content="Lock video render rate to source FPS (saves CPU/GPU on low-fps content)"
                                  ToolTip.Tip="Each Avalonia video output paces its render-request loop to the source's nominal frame rate instead of the display vsync. Reduces redundant work; may add a sub-frame of latency."/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Default volume"
                                   VerticalAlignment="Center" FontSize="12"/>
                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Slider Width="240" Minimum="0" Maximum="200"
                                    Value="{Binding VolumePercent, Mode=TwoWay}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding VolumePercent, StringFormat='{}{0:F0} %'}"
                                       VerticalAlignment="Center" FontSize="12" MinWidth="48"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- A/V drift correction -->
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="Auto, *">
                        <TextBlock Grid.Column="0" Text="A/V DRIFT CORRECTION"
                                   FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Margin="0,0,8,0"/>
                        <Border Grid.Column="1" Height="1" VerticalAlignment="Center"
                                Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                    </Grid>
                    <TextBlock TextWrapping="Wrap" FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Text="Background loop that nudges audio/video back into sync. Smaller MaxStepMs and a lower CorrectionGain are gentler but slower to converge."/>
                    <Grid ColumnDefinitions="220, *, 80" RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto" RowSpacing="6" ColumnSpacing="12">

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Initial delay (s)" VerticalAlignment="Center" FontSize="12"/>
                        <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="60" Value="{Binding AvInitialDelaySec, Mode=TwoWay}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding AvInitialDelaySec, StringFormat='{}{0:F1}'}" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Sample interval (s)" VerticalAlignment="Center" FontSize="12"/>
                        <Slider Grid.Row="1" Grid.Column="1" Minimum="0.5" Maximum="30" Value="{Binding AvIntervalSec, Mode=TwoWay}"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding AvIntervalSec, StringFormat='{}{0:F1}'}" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Min drift to correct (ms)" VerticalAlignment="Center" FontSize="12"/>
                        <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="50" Value="{Binding AvMinDriftMs, Mode=TwoWay}"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding AvMinDriftMs, StringFormat='{}{0:F1}'}" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Outlier cap (ms)" VerticalAlignment="Center" FontSize="12"/>
                        <Slider Grid.Row="3" Grid.Column="1" Minimum="50" Maximum="2000" Value="{Binding AvIgnoreOutlierDriftMs, Mode=TwoWay}"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding AvIgnoreOutlierDriftMs, StringFormat='{}{0:F0}'}" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Outlier confirmations" VerticalAlignment="Center" FontSize="12"/>
                        <Slider Grid.Row="4" Grid.Column="1" Minimum="1" Maximum="10" Value="{Binding AvOutlierConsecutiveSamples, Mode=TwoWay}" IsSnapToTickEnabled="True" TickFrequency="1"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding AvOutlierConsecutiveSamples}" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Correction gain" VerticalAlignment="Center" FontSize="12"/>
                        <Slider Grid.Row="5" Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding AvCorrectionGain, Mode=TwoWay}"/>
                        <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding AvCorrectionGain, StringFormat='{}{0:F2}'}" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Max step (ms)" VerticalAlignment="Center" FontSize="12"/>
                        <Slider Grid.Row="6" Grid.Column="1" Minimum="1" Maximum="50" Value="{Binding AvMaxStepMs, Mode=TwoWay}"/>
                        <TextBlock Grid.Row="6" Grid.Column="2" Text="{Binding AvMaxStepMs, StringFormat='{}{0:F1}'}" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Max abs offset (ms)" VerticalAlignment="Center" FontSize="12"/>
                        <Slider Grid.Row="7" Grid.Column="1" Minimum="50" Maximum="5000" Value="{Binding AvMaxAbsOffsetMs, Mode=TwoWay}"/>
                        <TextBlock Grid.Row="7" Grid.Column="2" Text="{Binding AvMaxAbsOffsetMs, StringFormat='{}{0:F0}'}" VerticalAlignment="Center"/>

                    </Grid>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Settings file" FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <SelectableTextBlock Text="{Binding SettingsPath}" FontSize="11"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <TextBlock Grid.Row="2"
                   Margin="12,4,12,8"
                   Text="{Binding StatusMessage}"
                   FontSize="11"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
    </Grid>
</UserControl>
