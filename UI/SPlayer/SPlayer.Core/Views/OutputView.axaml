<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:SPlayer.Core.ViewModels"
             xmlns:models="clr-namespace:SPlayer.Core.Models"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
             x:Class="SPlayer.Core.Views.OutputView"
             x:DataType="viewModels:OutputViewModel">

    <Design.DataContext>
        <viewModels:OutputViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Ellipse.status">
            <Setter Property="Fill" Value="#757575"/>
        </Style>
        <Style Selector="Ellipse.status.running">
            <Setter Property="Fill" Value="#4CAF50"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *">

        <!-- Toolbar -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Outputs"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,10,0"/>
                <Button Content="+ Audio"
                        Command="{Binding AddAudioEndpointCommand}"
                        CommandParameter="{Binding $parent[Window]}"/>
                <!-- §sdl3-output — split-button: clicking the main face uses the
                     default Avalonia backend; the chevron opens a flyout that
                     also offers SDL3 (its own native window + dedicated render
                     thread, recommended for heavy 4K content where the
                     Avalonia dispatcher can stall). -->
                <SplitButton Content="+ Video"
                             Command="{Binding AddAvaloniaVideoEndpointCommand}"
                             CommandParameter="{Binding $parent[Window]}">
                    <SplitButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuItem Header="Avalonia (default)"
                                      Command="{Binding AddAvaloniaVideoEndpointCommand}"
                                      CommandParameter="{Binding $parent[Window]}"/>
                            <MenuItem Header="SDL3 (dedicated window + render thread)"
                                      Command="{Binding AddSdl3VideoEndpointCommand}"
                                      CommandParameter="{Binding $parent[Window]}"/>
                        </MenuFlyout>
                    </SplitButton.Flyout>
                </SplitButton>
                <Button Content="+ NDI"
                        Command="{Binding AddNdiEndpointCommand}"
                        CommandParameter="{Binding $parent[Window]}"/>
            </StackPanel>
        </Border>

        <!-- Endpoint lists -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="12,10" Spacing="16">

                <!-- Audio section -->
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="Auto, *">
                        <TextBlock Grid.Column="0"
                                   Text="AUDIO"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Margin="0,0,8,0"/>
                        <Border Grid.Column="1"
                                Height="1"
                                VerticalAlignment="Center"
                                Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding AudioEndpointModels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:AudioEndpointModel">
                                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="12,8"
                                        Margin="0,0,0,4">
                                    <Grid ColumnDefinitions="16, *, Auto">
                                        <Ellipse Grid.Column="0"
                                                 Classes="status"
                                                 Classes.running="{Binding Open}"
                                                 Width="8" Height="8"
                                                 VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Spacing="1" Margin="8,0,12,0">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13"
                                                       FontWeight="Medium"/>
                                            <TextBlock Text="{Binding Info}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                            <Button Content="Start" Padding="10,3" FontSize="12"
                                                    Command="{Binding StartCommand}"/>
                                            <Button Content="Stop" Padding="10,3" FontSize="12"
                                                    Command="{Binding StopCommand}"/>
                                        </StackPanel>
                                    </Grid>
                                    <Border.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuItem Header="Start" Command="{Binding StartCommand}"/>
                                            <MenuItem Header="Stop" Command="{Binding StopCommand}"/>
                                            <MenuItem Header="Restart" Command="{Binding RestartCommand}"/>
                                            <Separator/>
                                            <MenuItem Header="Remove" Command="{Binding RemoveCommand}"/>
                                        </MenuFlyout>
                                    </Border.ContextFlyout>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Video section -->
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="Auto, *">
                        <TextBlock Grid.Column="0"
                                   Text="VIDEO"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Margin="0,0,8,0"/>
                        <Border Grid.Column="1"
                                Height="1"
                                VerticalAlignment="Center"
                                Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding VideoEndpointModels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:VideoEndpointModel">
                                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="12,8"
                                        Margin="0,0,0,4">
                                    <Grid ColumnDefinitions="16, *, Auto">
                                        <Ellipse Grid.Column="0"
                                                 Classes="status"
                                                 Classes.running="{Binding Open}"
                                                 Width="8" Height="8"
                                                 VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Spacing="1" Margin="8,0,12,0">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13"
                                                       FontWeight="Medium"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding Info}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                                <!-- §sdl3-output — visible badge when the per-row
                                                     "Lock to source FPS" override is active so the
                                                     user doesn't have to right-click to find out
                                                     which outputs are paced to source. -->
                                                <Border Background="{DynamicResource SystemAccentColorDark1}"
                                                        CornerRadius="2"
                                                        Padding="4,0"
                                                        VerticalAlignment="Center"
                                                        IsVisible="{Binding LimitRenderToInputFps}">
                                                    <TextBlock Text="FPS LOCK"
                                                               FontSize="9"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                            <Button Content="Start" Padding="10,3" FontSize="12"
                                                    Command="{Binding StartCommand}"/>
                                            <Button Content="Stop" Padding="10,3" FontSize="12"
                                                    Command="{Binding StopCommand}"/>
                                        </StackPanel>
                                    </Grid>
                                    <Border.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuItem Header="Start" Command="{Binding StartCommand}"/>
                                            <MenuItem Header="Stop" Command="{Binding StopCommand}"/>
                                            <MenuItem Header="Restart" Command="{Binding RestartCommand}"/>
                                            <Separator/>
                                            <MenuItem Header="Remove" Command="{Binding RemoveCommand}"/>
                                            <Separator/>
                                            <CheckBox Content="Debug HUD" IsChecked="{Binding DebugHUDEnabled}"/>
                                            <!-- §sdl3-output — per-row override of the global
                                                 LimitRenderFpsToSource setting. Convenient when you
                                                 want only the SDL3 output paced to source FPS while
                                                 the Avalonia output keeps free-running, or vice
                                                 versa. The global setting in the Settings tab still
                                                 seeds newly-added rows; toggling this is just a
                                                 live override. -->
                                            <CheckBox Content="Lock to source FPS"
                                                      IsChecked="{Binding LimitRenderToInputFps}"
                                                      ToolTip.Tip="Pace the renderer to the source video's frame rate instead of the display vsync. Recommended for heavy 4K/HDR sources where the GPU can't sustain a full vsync rate."/>
                                        </MenuFlyout>
                                    </Border.ContextFlyout>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- NDI section -->
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="Auto, *">
                        <TextBlock Grid.Column="0"
                                   Text="NDI"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Margin="0,0,8,0"/>
                        <Border Grid.Column="1"
                                Height="1"
                                VerticalAlignment="Center"
                                Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding NdiEndpointModels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:NDIEndpointModel">
                                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="12,8"
                                        Margin="0,0,0,4">
                                    <Grid ColumnDefinitions="16, *, Auto">
                                        <Ellipse Grid.Column="0"
                                                 Classes="status"
                                                 Classes.running="{Binding Open}"
                                                 Width="8" Height="8"
                                                 VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Spacing="1" Margin="8,0,12,0">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13"
                                                       FontWeight="Medium"/>
                                            <TextBlock Text="{Binding Info}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                            <Button Content="Start" Padding="10,3" FontSize="12"
                                                    Command="{Binding StartCommand}"/>
                                            <Button Content="Stop" Padding="10,3" FontSize="12"
                                                    Command="{Binding StopCommand}"/>
                                        </StackPanel>
                                    </Grid>
                                    <Border.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuItem Header="Start" Command="{Binding StartCommand}"/>
                                            <MenuItem Header="Stop" Command="{Binding StopCommand}"/>
                                            <MenuItem Header="Restart" Command="{Binding RestartCommand}"/>
                                            <Separator/>
                                            <MenuItem Header="Remove" Command="{Binding RemoveCommand}"/>
                                        </MenuFlyout>
                                    </Border.ContextFlyout>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>

</UserControl>
