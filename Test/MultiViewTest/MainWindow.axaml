<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MultiViewTest.MainWindow"
        Width="1280"
        Height="820"
        Title="MultiViewTest (4× cloned output stress test)">
    <Grid RowDefinitions="Auto,Auto,*" Margin="12">
        <TextBlock x:Name="SummaryText"
                   FontSize="14"
                   FontWeight="Bold"
                   Text="MultiViewTest — 4 cloned Avalonia GL outputs" />
        <TextBlock x:Name="StatusText"
                   Grid.Row="1"
                   Margin="0,6,0,10"
                   TextWrapping="Wrap"
                   Text="Hotkeys: Space=Play/Pause, Left/Right=Seek ±5s, H=HUD, Esc=Close" />
        <Grid x:Name="ViewGrid"
              Grid.Row="2"
              ColumnDefinitions="*,*"
              RowDefinitions="*,*"
              ColumnSpacing="8"
              RowSpacing="8" />
    </Grid>
</Window>

