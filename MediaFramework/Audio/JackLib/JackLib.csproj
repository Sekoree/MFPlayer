<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <IsAotCompatible>true</IsAotCompatible>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    </ItemGroup>

    <ItemGroup>
        <!-- S.Media.PortAudio uses JackLib for JACK port/connection management. -->
        <InternalsVisibleTo Include="S.Media.PortAudio" />
        <InternalsVisibleTo Include="S.Media.PortAudio.Tests" />
        <InternalsVisibleTo Include="JackLib.Tests" />
    </ItemGroup>

</Project>

