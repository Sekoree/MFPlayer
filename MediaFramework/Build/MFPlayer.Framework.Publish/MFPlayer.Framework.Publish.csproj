<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Meta-package: no source code. Referenced only so `dotnet publish` can produce a single
    folder (../../FrameworkBuilds/net10.0) containing all MFPlayer framework assemblies and
    their NuGet/native dependencies. See MediaFramework/Scripts/build-framework.sh
  -->
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>MFPlayer.Framework.Publish</RootNamespace>
    <IsPackable>false</IsPackable>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <EnableDefaultEmbeddedResourceItems>false</EnableDefaultEmbeddedResourceItems>
    <NoWarn>$(NoWarn);CS2008</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Media\S.Media.Core\S.Media.Core.csproj" />
    <ProjectReference Include="..\..\Media\S.Media.FFmpeg\S.Media.FFmpeg.csproj" />
    <ProjectReference Include="..\..\Media\S.Media.Playback\S.Media.Playback.csproj" />
    <ProjectReference Include="..\..\Audio\S.Media.PortAudio\S.Media.PortAudio.csproj" />
    <ProjectReference Include="..\..\Audio\PALib\PALib.csproj" />
    <ProjectReference Include="..\..\Audio\JackLib\JackLib.csproj" />
    <ProjectReference Include="..\..\Video\S.Media.SDL3\S.Media.SDL3.csproj" />
    <ProjectReference Include="..\..\Video\S.Media.Avalonia\S.Media.Avalonia.csproj" />
    <ProjectReference Include="..\..\NDI\NDILib\NDILib.csproj" />
    <ProjectReference Include="..\..\NDI\S.Media.NDI\S.Media.NDI.csproj" />
    <ProjectReference Include="..\..\NDI\S.Media.NDI.Playback\S.Media.NDI.Playback.csproj" />
    <ProjectReference Include="..\..\OSC\OSCLib\OSCLib.csproj" />
    <ProjectReference Include="..\..\MIDI\PMLib\PMLib.csproj" />
  </ItemGroup>

  <!-- Satisfy SDK when no .cs files exist -->
  <ItemGroup>
    <Compile Include="$(MSBuildThisFileDirectory)Dummy.cs" />
  </ItemGroup>

  <!-- The meta assembly is only needed to drive publish; drop it from the consumer drop folder. -->
  <Target Name="RemoveMetaAssemblyFromPublish" AfterTargets="Publish">
    <ItemGroup>
      <_MetaToDelete Include="$(PublishDir)MFPlayer.Framework.Publish.dll" />
      <_MetaToDelete Include="$(PublishDir)MFPlayer.Framework.Publish.pdb" />
      <_MetaToDelete Include="$(PublishDir)MFPlayer.Framework.Publish.deps.json" />
    </ItemGroup>
    <Delete Files="@(_MetaToDelete)" ContinueOnError="true" />
  </Target>

</Project>
